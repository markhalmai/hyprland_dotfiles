{
  "position": "top",
  "height": 34,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": [],
  "modules-right": ["hyprland/language", "pulseaudio", "tray", "clock"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "on-click": "activate",
    "move-to-monitor": true,
    "sort-by": "number",
    "format": "{name}"
  },

  "hyprland/language": {
  "format": "{short}",
  "tooltip": false
  },

  "pulseaudio": {
    "format": "  {volume}%",
    "on-click": "pavucontrol"
  },

  "clock": {
    "format": "{:%a %d %b  %H:%M}"
  },

  "tray": { "icon-size": 16, "spacing": 8 }
}
